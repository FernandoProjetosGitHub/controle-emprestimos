{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Controle de Emprestimos",
  "version": "0.1.0",
  "identifier": "com.fernandoprojetos.controleemprestimos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Controle de Empréstimos",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Finance",
    "shortDescription": "Controle de empréstimos",
    "longDescription": "Aplicativo local para controle de clientes e empréstimos com sincronização opcional via Firebase."
  }
}
